<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StockDental | Segmented Experience</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #040712; }
        .glass-card { background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.08); }
        .nav-pill { transition: all 0.3s; border: 1px solid rgba(34, 211, 238, 0.2); }
        .nav-pill.active { background-color: #22d3ee; color: #000; font-weight: bold; }
    </style>
</head>
<body class="text-slate-200">

    <nav class="sticky top-0 z-50 bg-[#040712]/90 backdrop-blur-xl border-b border-white/5 p-4">
        <div class="max-w-5xl mx-auto flex justify-between items-center">
            <h1 class="text-xl font-extrabold tracking-tighter">STOCK<span class="text-cyan-400">DENTAL</span></h1>
            <div id="cart-count" class="bg-cyan-500 text-black text-[10px] font-bold px-2 py-1 rounded-lg">🛒 0</div>
        </div>
    </nav>

    <!-- Menú de Perfiles -->
    <section class="max-w-5xl mx-auto px-6 py-4 flex gap-3 overflow-x-auto no-scrollbar">
        <button onclick="filter('todos')" class="nav-pill active whitespace-nowrap px-6 py-2 rounded-2xl text-xs uppercase tracking-widest">Todos</button>
        <button onclick="filter('odontologo')" class="nav-pill whitespace-nowrap px-6 py-2 rounded-2xl text-xs uppercase tracking-widest text-cyan-400">Odontólogos</button>
        <button onclick="filter('tecnico')" class="nav-pill whitespace-nowrap px-6 py-2 rounded-2xl text-xs uppercase tracking-widest text-cyan-400">Técnicos</button>
        <button onclick="filter('estudiante')" class="nav-pill whitespace-nowrap px-6 py-2 rounded-2xl text-xs uppercase tracking-widest text-cyan-400">Estudiantes</button>
    </section>

    <main id="catalog" class="max-w-5xl mx-auto p-6 grid grid-cols-1 md:grid-cols-2 gap-6 pb-40">
        <!-- Los productos se cargan dinámicamente o se filtran aquí -->
    </main>

    <script>
        const productos = [
            { id: 1, name: "Yeso Whip Mix T4", price: 6599, cat: "tecnico", desc: "Precisión extrema para troqueles." },
            { id: 2, name: "Guantes Ecomed", price: 5628, cat: "odontologo", desc: "Alta resistencia y agarre instrumental." },
            { id: 3, name: "Cera Bon Dent", price: 7198, cat: "tecnico", desc: "Estabilidad térmica para modelado." },
            { id: 4, name: "Yeso Blanco Chong", price: 1800, cat: "estudiante", desc: "Ideal para prácticas y modelos de estudio." },
            { id: 5, name: "Acrílico Privanic", price: 3666, cat: "tecnico", desc: "Pureza garantizada sin porosidad." }
        ];

        function render(filterCat = 'todos') {
            const container = document.getElementById('catalog');
            container.innerHTML = "";
            const filtered = filterCat === 'todos' ? productos : productos.filter(p => p.cat === filterCat);
            
            filtered.forEach(p => {
                container.innerHTML += `
                    <div class="glass-card rounded-[2rem] p-6 flex flex-col justify-between">
                        <div>
                            <span class="text-[9px] text-cyan-400 font-bold uppercase tracking-widest">${p.cat}</span>
                            <h3 class="text-xl font-bold text-white mt-2">${p.name}</h3>
                            <p class="text-sm text-slate-400 mt-2">${p.desc}</p>
                        </div>
                        <div class="flex justify-between items-center mt-6">
                            <span class="text-xl font-black">${p.price} Bs.</span>
                            <button class="bg-white text-black px-6 py-2 rounded-xl font-bold text-xs uppercase">Añadir</button>
                        </div>
                    </div>
                `;
            });
        }

        function filter(cat) {
            document.querySelectorAll('.nav-pill').forEach(b => b.classList.remove('active'));
            event.target.classList.add('active');
            render(cat);
        }

        render(); // Carga inicial
    </script>
</body>
</html>
